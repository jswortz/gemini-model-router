# Copy to `.env` (gitignored) — the router auto-loads it on startup.
# Anything already exported in your shell wins over values here.

# HuggingFace read token. Optional, but silences the
# "sending unauthenticated requests to the HF Hub" warning and raises
# rate limits when the MiniLM anchor cache is rebuilt.
# Get one at https://huggingface.co/settings/tokens
HF_TOKEN=

# Vendor API keys for the CLI backends. Only needed if the corresponding
# `<vendor> CLI` is not already authenticated some other way (e.g. via
# `gemini auth` or an existing `claude` login).
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: silence the cosmetic `embeddings.position_ids UNEXPECTED`
# warning from sentence-transformers loading the MiniLM checkpoint.
# Uncomment to apply.
# TRANSFORMERS_VERBOSITY=error
